{
  "schemaVersion": 1,
  "id": "btc",
  "version": "${version}",
  "name": "BTC",
  "description": "BTC is a Minecraft mod adding custom trial chambers, multiple new mobs, a magic system, and interactive systems like dungeon wires and a multitude of dungeon puzzles.",
  "authors": [
    "TobinOakenshield"
  ],
  "contact": {
    "repo": "https://github.com/TobyRue/BTC"
  },
  "license": "BTC-GPLv1.0",
  "icon": "assets/btc/btc_title.png",
  "environment": "*",
  "entrypoints": {
    "main": [
      "io.github.tobyrue.btc.BTC"
    ],
    "fabric-datagen": [
      "io.github.tobyrue.btc.ExampleModDataGenerator"
    ],
    "client": [
      "io.github.tobyrue.btc.client.BTCClient"
    ],
    "mm:early_risers": [
      "io.github.tobyrue.btc.regestries.EarlyRiser"
    ]
  },
  "mixins": [
    "btc.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=${loader_version}",
    "fabric": "*",
    "minecraft": "${minecraft_version}"
  }
}
